# Пример конфига Redis для прод-стека. Скопируйте на хост как /opt/prct-site/redis.conf,
# впишите реальный пароль и ограничьте права (см. README, раздел про Redis).
# НАСТОЯЩИЙ redis.conf в git НЕ коммитится (см. .gitignore) — в нём лежит секрет.

# Пароль на подключение. Замените на длинный случайный (openssl rand -hex 32).
requirepass ЗАМЕНИ_НА_ПАРОЛЬ

# Персистентность: сессии и баны fail2ban переживают рестарт контейнера.
appendonly yes
save 60 1
