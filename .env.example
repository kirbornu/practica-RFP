# Скопируйте в .env на хосте (/opt/prct-site/.env) и заполните.
# docker compose автоматически подхватывает .env из каталога со стеком.

# Секрет для подписи cookie-сессий. Обязателен в проде.
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-hex-string

# Адрес сайта для Caddy:
#   публичный домен  → example.com          (авто Let's Encrypt)
#   внутренний адрес → https://192.0.2.20  (внутренний self-signed CA)
SITE_ADDRESS=https://192.0.2.20

# Первый пользователь. Создаётся автоматически, только если users.json пуст.
INITIAL_ADMIN=admin
INITIAL_ADMIN_PASSWORD=change-me
